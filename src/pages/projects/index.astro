---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sitePath } from '../../lib/paths';
const projects = await getCollection('projects');
const posts = (await getCollection('posts')).filter((post) => !post.data.draft);
---

<BaseLayout title="Projects" currentPath="/projects/">
  <div class="container section">
    <p class="mono">$ ls projects/</p><h1 class="page-title">Projects</h1><div class="post-list">
      {
        projects.map((project) => (
          <article class="post-row">
            <>
              <h2>
                <a href={sitePath(`/projects/${project.id}/`)}>{project.data.title}</a>
              </h2>
              <p>{project.data.summary}</p>
              <div class="meta">
                <>
                  <span class="status">{project.data.status}</span>
                  <span>{project.data.role}</span>
                  <span>{project.data.stack.join(' · ')}</span>
                </>
              </div>
              {project.data.relatedPosts && project.data.relatedPosts.length > 0 && (
                <div class="project-log-links">
                  <strong>Project Logs</strong>
                  <ul>
                    {project.data.relatedPosts.map((postId) => {
                      const post = posts.find((item) => item.id === postId);
                      return post ? (
                        <li>
                          <a href={sitePath(`/posts/${post.id}/`)}>{post.data.title}</a>
                        </li>
                      ) : null;
                    })}
                  </ul>
                </div>
              )}
            </>
          </article>
        ))
      }
    </div>
  </div>
</BaseLayout>
