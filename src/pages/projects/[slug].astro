---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const data = project.data;
---

<BaseLayout title={data.title} currentPath="/projects/">
  <main class="project-detail">
    <div class="project-shell">
      <header class="project-hero">
        <p class="project-kicker mono">
          <span>PROJECT</span><span aria-hidden="true">/</span><span>CASE STUDY</span>
        </p>
        <h1>{data.title}</h1>
        <p class="project-summary">{data.summary}</p>
      </header>

      <section class="project-spec" aria-label="Project specification">
        <div class="project-spec-head">
          <span class="project-terminal-title"
            ><i></i><i></i><i></i><span class="mono">cat project.json</span></span
          >
          <span class="mono">JSON</span>
        </div>
        <div class="project-spec-code mono" aria-label="Project JSON configuration">
          <span class="json-brace">&#123;</span>
          <div class="project-json-grid">
            <div>
              <div><span class="json-key">"status"</span>: <span>"{data.status}"</span>,</div>
              <div><span class="json-key">"role"</span>: <span>"{data.role}"</span>,</div>
            </div>
            <div>
              <div>
                <span class="json-key">"period"</span>:
                <span>"{data.startedAt} – {data.endedAt ?? 'YYYY.MM.DD'}"</span>,
              </div>
              <div>
                <span class="json-key">"stack"</span>: [
                {
                  data.stack.map((item, index) => (
                    <span>
                      {' '}
                      "{item}"{index < data.stack.length - 1 ? ', ' : ''}
                    </span>
                  ))
                } ]
              </div>
            </div>
          </div>
          <span class="json-brace">&#125;</span>
        </div>
      </section>

      <article class="project-content article-body">
        <Content />
      </article>

      <nav class="project-pagination" aria-label="Project navigation">
        <a href="/projects/" class="project-nav-card">
          <span class="mono">Previous Project</span>
          <strong>All Projects</strong>
        </a>
        <a href="/projects/" class="project-nav-card project-nav-next">
          <span class="mono">Next Project</span>
          <strong>Explore Projects</strong>
        </a>
      </nav>
    </div>
  </main>
</BaseLayout>
