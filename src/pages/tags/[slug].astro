---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostRow from '../../components/PostRow.astro';
import { sortPosts } from '../../lib/posts';
import { toSlug } from '../../lib/slug';
import { sitePath } from '../../lib/paths';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => !post.data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
  return tags.map((tag) => ({ params: { slug: toSlug(tag) }, props: { tag, posts } }));
}

const { tag, posts } = Astro.props;
const filteredPosts = sortPosts(posts.filter((post) => post.data.tags.includes(tag)));
---

<BaseLayout title={`#${tag}`} currentPath="/tags/">
  <div class="container section">
    <nav class="breadcrumbs" aria-label="태그 위치">
      <a href={sitePath('/tags/')}>Tags</a><span aria-hidden="true">/</span><span>#{tag}</span>
    </nav>
    <p class="mono">$ grep -l #{tag} posts/*</p>
    <h1 class="page-title">#{tag}</h1>
    <p>{filteredPosts.length}개의 게시글</p>
    <div class="post-list">
      {filteredPosts.map((post) => <PostRow post={post} />)}
    </div>
    <p><a href={sitePath('/tags/')}>← 모든 태그</a></p>
  </div>
</BaseLayout>
