---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readingTime, sortPosts } from '../../lib/posts';
import { toSlug } from '../../lib/slug';
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({ params: { slug: post.id }, props: { post, posts } }));
}
const { post, posts } = Astro.props;
const { Content } = await render(post);
const data = Object.assign(
  {
    title: '',
    type: 'Learning Notes',
    category: 'AI Agents',
    publishedAt: '',
    updatedAt: undefined,
    tags: [] as string[],
  },
  post.data,
);
const ordered = sortPosts(posts.filter((item) => !item.data.draft));
const index = ordered.findIndex((item) => item.id === post.id);
const previous = ordered[index + 1];
const next = ordered[index - 1];
---

<BaseLayout title={data.title}
  ><div class="container section">
    <div class="article-layout">
      <details class="toc" open>
        <summary>[+] Contents</summary><ul>
          <li><a href="#introduction">도입</a></li><li><a href="#implementation">본문</a></li>
        </ul>
      </details><article>
        <header class="article-header">
          <div class="meta mono">[{data.type}] · {data.category}</div><h1 class="page-title">
            {data.title}
          </h1><div class="meta">
            <span>{data.publishedAt}</span>{
              data.updatedAt && <span>수정 {data.updatedAt}</span>
            }<span>읽는 시간 {readingTime(post.body ?? '')}분</span>
          </div>
        </header><div id="introduction" class="article-body">
          <span id="implementation" aria-hidden="true"></span><Content />
        </div><ul class="tag-list">
          {
            data.tags.map((tag) => (
              <li class="tag">
                <a href={`/tags/${toSlug(tag)}/`}>#{tag}</a>
              </li>
            ))
          }
        </ul><nav aria-label="게시글 이동" class="footer-nav">
          {
            previous && (
              <a href={`/posts/${previous.id}/`}>
                ← {Object.assign({ title: '' }, previous.data).title}
              </a>
            )
          }{
            next && (
              <a href={`/posts/${next.id}/`}>{Object.assign({ title: '' }, next.data).title} →</a>
            )
          }
        </nav>
      </article>
    </div>
  </div></BaseLayout
>
