---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostRow from '../../components/PostRow.astro';
import { sortPosts } from '../../lib/posts';
import { toSlug } from '../../lib/slug';
import { sitePath } from '../../lib/paths';

const typeLabels = {
  'technical-articles': 'Technical Notes',
  'learning-notes': 'Learning Notes',
  'project-retrospectives': 'Project Retrospectives',
} as const;

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => !post.data.draft);
  const types = [...new Set(posts.map((post) => post.data.type))];
  return types.map((type) => ({
    params: { type: toSlug(type) },
    props: { type, posts },
  }));
}

const { type, posts } = Astro.props;
const typeSlug = toSlug(type);
const label = typeLabels[typeSlug as keyof typeof typeLabels] ?? type;
const filteredPosts = sortPosts(posts.filter((post) => post.data.type === type));
---

<BaseLayout title={label} currentPath={`/logs/${typeSlug}/`}>
  <div class="container section">
    <nav class="breadcrumbs" aria-label="Log location">
      <a href={sitePath('/logs/')}>Logs</a><span aria-hidden="true">/</span><span>{label}</span>
    </nav>
    <p class="mono">$ find logs -type {typeSlug}</p>
    <h1 class="page-title">{label}</h1>
    {
      filteredPosts.length ? (
        <div class="post-list">
          {filteredPosts.map((post) => <PostRow post={post} />)}
        </div>
      ) : (
        <div class="empty-state"><p>No logs have been published in this type yet.</p></div>
      )
    }
  </div>
</BaseLayout>
