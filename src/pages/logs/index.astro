---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostRow from '../../components/PostRow.astro';
import { sortPosts } from '../../lib/posts';

const posts = sortPosts((await getCollection('posts')).filter((post) => !post.data.draft));
---

<BaseLayout title="All Logs" currentPath="/logs/">
  <div class="container section">
    <p class="mono">$ find logs -type f</p>
    <h1 class="page-title">All Logs</h1>
    {
      posts.length ? (
        <div class="post-list">
          {posts.map((post) => <PostRow post={post} />)}
        </div>
      ) : (
        <div class="empty-state"><p>No logs have been published yet.</p></div>
      )
    }
  </div>
</BaseLayout>
