---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/HomeHero.astro';
import EmptyState from '../components/EmptyState.astro';
import CategoryFilter from '../components/CategoryFilter.astro';
import PostRow from '../components/PostRow.astro';
import { sortPosts } from '../lib/posts';
const posts = sortPosts((await getCollection('posts')).filter((post) => !post.data.draft));
const categories = ['AI Agents', 'Frontend', 'Backend', 'Astro'];
---

<BaseLayout currentPath="/" title="Home">
  <HomeHero />
  <div class="container home-content">
    <section class="home-section home-introduction" aria-labelledby="intro-title">
      <header class="indexed-heading">
        <h2 id="intro-title" class="mono"><span>01</span><span>/</span>INTRODUCTION</h2>
        <span class="heading-line" aria-hidden="true"></span>
      </header>
      <p class="introduction-copy">
        기술적 배움의 과정, 문제 해결의 기록, 그리고 실제 구동되는 서비스들을 기록하는 공간입니다.
        단순한 코드의 나열을 넘어, AI와의 협업을 통해 아이디어가 현실화되는 과정을 아카이빙합니다.
      </p>
      <div class="signal-trace" aria-hidden="true">
        <svg viewBox="0 0 1040 64" preserveAspectRatio="none" focusable="false">
          <path
            d="M0 52 H282 L318 34 L342 45 L396 40 L456 14 L570 40 L684 6 L698 13 L711 9 L820 52 H1040"
          ></path>
        </svg>
      </div>
    </section>
    <section class="home-section latest-logs" aria-labelledby="latest-title">
      <header class="indexed-heading">
        <h2 id="latest-title" class="mono"><span>02</span><span>/</span>LATEST_LOGS</h2>
        <span class="heading-line" aria-hidden="true"></span>
      </header>
      {
        posts.length > 0 ? (
          <>
            <CategoryFilter categories={categories} />
            <div class="post-list">
              {posts.map((post) => (
                <PostRow post={post} />
              ))}
            </div>
          </>
        ) : (
          <EmptyState />
        )
      }
    </section>
  </div>
</BaseLayout>

<style>
  .home-content {
    padding-bottom: 96px;
  }

  .home-section {
    padding-top: 96px;
  }

  .home-introduction {
    padding-bottom: 62px;
  }

  .indexed-heading {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .indexed-heading h2 {
    display: flex;
    flex: none;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: var(--mute);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1.5;
  }

  .indexed-heading h2 span:first-child {
    color: var(--body);
  }

  .heading-line {
    width: 100%;
    height: 1px;
    background: var(--hairline);
  }

  .introduction-copy {
    max-width: 780px;
    margin: 32px 0 0;
    color: var(--ink);
    font-size: 18px;
    line-height: 1.75;
    word-break: keep-all;
  }

  .signal-trace {
    width: 100%;
    height: 64px;
    margin-top: 92px;
  }

  .signal-trace svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .signal-trace path {
    fill: none;
    stroke: var(--hairline);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .latest-logs .indexed-heading {
    margin-bottom: 36px;
  }

  @media (max-width: 640px) {
    .home-content {
      padding-bottom: 64px;
    }

    .home-section {
      padding-top: 64px;
    }

    .home-introduction {
      padding-bottom: 48px;
    }

    .introduction-copy {
      margin-top: 28px;
      font-size: 17px;
      line-height: 1.8;
    }

    .signal-trace {
      height: 48px;
      margin-top: 56px;
    }

    .latest-logs .indexed-heading {
      margin-bottom: 28px;
    }
  }
</style>
