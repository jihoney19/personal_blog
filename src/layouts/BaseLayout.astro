---
import '../styles/global.css';
import { navigation, site } from '../data/site';
import { sitePath } from '../lib/paths';
const basePath = import.meta.env.BASE_URL.replace(/\/$/u, '');
const {
  title = site.name,
  description = site.description,
  currentPath = Astro.url.pathname,
} = Astro.props;
const normalizedCurrentPath = currentPath.replace(basePath, '') || '/';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} · {site.name}</title>
    <script is:inline>
      let saved = null;
      try {
        saved = localStorage.getItem('theme');
      } catch {
        document.documentElement.dataset.themePersistence = 'unavailable';
      }
      const preferred =
        saved === 'dark' || saved === 'light'
          ? saved
          : matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
      document.documentElement.dataset.theme = preferred;
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="container site-nav">
          <a class="brand mono" href={sitePath('/')}>{site.name}</a>
          <nav class="desktop-nav" aria-label="데스크톱 전역 탐색">
            {
              navigation.map((item) => (
                <a
                  href={item.href}
                  aria-current={
                    normalizedCurrentPath === item.href.replace(basePath, '') ? 'page' : undefined
                  }
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <button class="theme-button" type="button" data-theme-toggle aria-label="다크 모드로 전환"
            ><span class="theme-label mono">MODE: LIGHT</span></button
          >
          <div class="mobile-actions">
            <button
              class="theme-button"
              type="button"
              data-theme-toggle
              aria-label="다크 모드로 전환"
              ><span class="theme-label mono">MODE: LIGHT</span></button
            >
            <button
              class="menu-button"
              type="button"
              data-menu-toggle
              aria-expanded="false"
              aria-controls="mobile-menu">메뉴</button
            >
          </div>
        </div>
        <nav
          id="mobile-menu"
          class="container menu-panel"
          data-menu-panel
          aria-label="모바일 전역 탐색"
          data-open="false"
        >
          {
            navigation.map((item) => (
              <a
                href={item.href}
                aria-current={
                  normalizedCurrentPath === item.href.replace(basePath, '') ? 'page' : undefined
                }
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </header>
      <main id="main-content"><slot /></main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <span class="mono">{site.name}</span>
          <nav class="footer-nav" aria-label="푸터 탐색">
            <a href={sitePath('/projects/')}>Projects</a><a href={sitePath('/about/')}>About</a>
          </nav>
          <span>GitHub는 검증된 실제 URL이 있을 때만 표시됩니다.</span>
        </div>
      </footer>
    </div>
    <script is:inline>
      const updateThemeLabels = () =>
        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          const dark = document.documentElement.dataset.theme === 'dark';
          button.setAttribute('aria-label', dark ? '라이트 모드로 전환' : '다크 모드로 전환');
          button.setAttribute('title', dark ? '라이트 모드로 전환' : '다크 모드로 전환');
          const label = button.querySelector('.theme-label');
          if (label) label.textContent = dark ? 'MODE: DARK' : 'MODE: LIGHT';
        });
      document.querySelectorAll('[data-theme-toggle]').forEach((button) =>
        button.addEventListener('click', () => {
          document.documentElement.dataset.theme =
            document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          try {
            localStorage.setItem('theme', document.documentElement.dataset.theme);
          } catch {
            document.documentElement.dataset.themePersistence = 'unavailable';
          }
          updateThemeLabels();
        }),
      );
      updateThemeLabels();
      const menuToggle = document.querySelector('[data-menu-toggle]');
      const menuPanel = document.querySelector('[data-menu-panel]');
      const closeMenu = () => {
        if (!menuToggle || !menuPanel) return;
        menuToggle.setAttribute('aria-expanded', 'false');
        menuPanel.dataset.open = 'false';
      };
      menuToggle?.addEventListener('click', () => {
        const open = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!open));
        if (menuPanel) menuPanel.dataset.open = String(!open);
        if (open) menuToggle.focus();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMenu();
          menuToggle?.focus();
        }
      });
    </script>
  </body>
</html>
