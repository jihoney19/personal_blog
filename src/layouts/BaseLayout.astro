---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { site } from '../data/site';
import PostNavigation from '../components/PostNavigation.astro';
import { sitePath } from '../lib/paths';
import { buildSiteNavigation } from '../lib/topic-navigation';
const basePath = import.meta.env.BASE_URL.replace(/\/$/u, '');
const navigationPosts = (await getCollection('posts')).filter((post) => !post.data.draft);
const siteNavigation = buildSiteNavigation();
const {
  title = site.name,
  description = site.description,
  currentPath = Astro.url.pathname,
  activeCategory,
  activeTopic,
} = Astro.props;
const normalizedCurrentPath = currentPath.replace(basePath, '') || '/';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} · {site.name}</title>
    <script is:inline>
      let saved = null;
      try {
        saved = localStorage.getItem('theme');
      } catch {
        document.documentElement.dataset.themePersistence = 'unavailable';
      }
      const preferred =
        saved === 'dark' || saved === 'light'
          ? saved
          : matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
      document.documentElement.dataset.theme = preferred;
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">본문으로 건너뛰기</a>
    <div class="site-shell">
      <PostNavigation
        posts={navigationPosts}
        currentPath={normalizedCurrentPath}
        activeCategory={activeCategory}
        activeTopic={activeTopic}
      />
      <header class="site-header">
        <div class="container site-nav">
          <a class="brand mono" href={sitePath('/')}>{site.name}</a>
          <nav class="desktop-nav" aria-label="데스크톱 전역 탐색">
            {
              siteNavigation.map((item) => (
                <a
                  href={item.href}
                  aria-current={
                    normalizedCurrentPath === item.href.replace(basePath, '') ? 'page' : undefined
                  }
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
          <button class="theme-button" type="button" data-theme-toggle aria-label="다크 모드로 전환"
            ><span class="theme-label mono">MODE: LIGHT</span></button
          >
          <div class="mobile-actions">
            <button
              class="theme-button"
              type="button"
              data-theme-toggle
              aria-label="다크 모드로 전환"
              ><span class="theme-label mono">MODE: LIGHT</span></button
            >
            <button
              class="menu-button"
              type="button"
              data-menu-toggle
              aria-expanded="false"
              aria-controls="mobile-menu">메뉴</button
            >
          </div>
        </div>
        <nav
          id="mobile-menu"
          class="container menu-panel"
          data-menu-panel
          aria-label="모바일 전역 탐색"
          data-open="false"
        >
          {
            siteNavigation.map((item) => {
              const children = item.children;
              return (
                <div class="mobile-menu-group">
                  <a
                    href={item.href}
                    aria-current={
                      normalizedCurrentPath === item.href.replace(basePath, '') ? 'page' : undefined
                    }
                  >
                    {item.label}
                  </a>
                  {children && (
                    <div class="mobile-menu-children">
                      {children.map((child) => (
                        <div class="mobile-menu-group">
                          <a
                            href={child.href}
                            aria-current={
                              normalizedCurrentPath === child.href.replace(basePath, '')
                                ? 'page'
                                : undefined
                            }
                          >
                            {child.label}
                          </a>
                          {child.children && (
                            <div class="mobile-menu-children">
                              {child.children.map((grandchild) => (
                                <a
                                  href={grandchild.href}
                                  aria-current={
                                    normalizedCurrentPath === grandchild.href.replace(basePath, '')
                                      ? 'page'
                                      : undefined
                                  }
                                >
                                  {grandchild.label}
                                </a>
                              ))}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              );
            })
          }
        </nav>
      </header>
      <main id="main-content"><slot /></main>
      <footer class="site-footer">
        <div class="container footer-inner">
          <span class="mono">{site.name}</span>
          <nav class="footer-nav" aria-label="푸터 탐색">
            <a href={sitePath('/projects/')}>Projects</a><a href={sitePath('/about/')}>About</a>
            {
              site.githubUrl && (
                <a href={site.githubUrl} target="_blank" rel="noreferrer">
                  GitHub
                </a>
              )
            }
          </nav>
        </div>
      </footer>
    </div>
    <script is:inline>
      const updateThemeLabels = () =>
        document.querySelectorAll('[data-theme-toggle]').forEach((button) => {
          const dark = document.documentElement.dataset.theme === 'dark';
          const current = dark ? 'DARK' : 'LIGHT';
          const action = dark ? '라이트 모드로 전환' : '다크 모드로 전환';
          button.setAttribute('aria-label', `현재 ${current} 모드 · ${action}`);
          button.setAttribute('title', `현재 ${current} 모드 · ${action}`);
          const label = button.querySelector('.theme-label');
          if (label) label.textContent = `MODE: ${current}`;
        });
      document.querySelectorAll('[data-theme-toggle]').forEach((button) =>
        button.addEventListener('click', () => {
          document.documentElement.dataset.theme =
            document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          try {
            localStorage.setItem('theme', document.documentElement.dataset.theme);
          } catch {
            document.documentElement.dataset.themePersistence = 'unavailable';
          }
          updateThemeLabels();
        }),
      );
      updateThemeLabels();
      const menuToggle = document.querySelector('[data-menu-toggle]');
      const menuPanel = document.querySelector('[data-menu-panel]');
      const closeMenu = () => {
        if (!menuToggle || !menuPanel) return;
        menuToggle.setAttribute('aria-expanded', 'false');
        menuPanel.dataset.open = 'false';
      };
      menuToggle?.addEventListener('click', () => {
        const open = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!open));
        if (menuPanel) menuPanel.dataset.open = String(!open);
        if (open) menuToggle.focus();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeMenu();
          menuToggle?.focus();
        }
      });
    </script>
  </body>
</html>
