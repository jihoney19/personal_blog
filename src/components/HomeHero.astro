---
import { site } from '../data/site';
const heroTitle = site.heroTitleLines.join(' ');
---

<section class="home-hero" aria-labelledby="hero-title">
  <div class="container home-hero-inner">
    <p class="hero-command mono"><span aria-hidden="true">$</span> whoami</p>
    <h1 id="hero-title" aria-label={heroTitle}>
      <span class="hero-statement">
        {
          site.heroTitleLines.map((line, index) => (
            <span class="hero-title-line">
              {line}
              {index === site.heroTitleLines.length - 1 && (
                <span class="terminal-cursor" aria-hidden="true" />
              )}
            </span>
          ))
        }
      </span>
    </h1>
  </div>
</section>

<style>
  .home-hero {
    min-height: 500px;
    border-bottom: 1px solid var(--hairline);
    background: var(--canvas);
    color: var(--ink);
  }

  .home-hero-inner {
    display: flex;
    min-height: 500px;
    flex-direction: column;
    justify-content: center;
    padding-block: 96px;
  }

  .hero-command {
    margin: 0 0 34px;
    color: var(--accent);
    font-size: 12px;
    font-weight: 600;
    line-height: 1.5;
  }

  .hero-command span {
    margin-right: 8px;
    color: var(--terminal-accent);
  }

  h1 {
    max-width: 940px;
    margin: 0;
    font-family: Georgia, 'Times New Roman', Pretendard, serif;
    font-size: clamp(46px, 6.8vw, 78px);
    line-height: 1.08;
    letter-spacing: -0.05em;
  }

  .hero-statement {
    display: block;
    max-width: 100%;
    color: inherit;
    font: inherit;
    font-weight: 700;
    text-align: left;
  }

  .terminal-cursor {
    display: inline-block;
    width: 0.09em;
    height: 0.82em;
    margin-left: 8px;
    background: var(--accent);
    vertical-align: 0.02em;
    animation: terminal-cursor-blink 0.9s steps(1, end) infinite;
  }

  @keyframes terminal-cursor-blink {
    50% {
      opacity: 0;
    }
  }

  .hero-title-line {
    display: block;
  }

  @media (max-width: 640px) {
    .home-hero,
    .home-hero-inner {
      min-height: 390px;
    }

    .home-hero-inner {
      padding-block: 64px;
    }

    h1 {
      font-size: 40px;
      line-height: 1.12;
    }
  }

  @media (max-width: 640px) {
    .terminal-cursor {
      width: 7px;
      height: 19px;
      margin-left: 7px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-cursor {
      animation: none;
    }
  }
</style>
