---
import { readingTime } from '../lib/posts';
import { toSlug } from '../lib/slug';
import { sitePath } from '../lib/paths';
const { post } = Astro.props;
const data = post.data;
---

<article class="post-row" data-post-category={data.category}>
  <h3>
    <a href={sitePath(`/posts/${post.id}/`)}><span class="mono">[{data.type}]</span> {data.title}</a
    >
  </h3>
  <div class="meta mono">
    <span>{data.publishedAt}</span><span>{data.category}</span><span
      >읽는 시간 {readingTime(post.body ?? '')}분</span
    >
  </div>
  <ul class="tag-list post-tags" aria-label="태그">
    {
      data.tags.map((tag: string) => (
        <li class="tag">
          <a href={sitePath(`/tags/${toSlug(tag)}/`)}>#{tag}</a>
        </li>
      ))
    }
  </ul>
  <p>{data.description}</p>
</article>
