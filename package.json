    "@playwright/test": "^1.55.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.7.0",
    "prettier": "^3.6.0",
    "prettier-plugin-astro": "^0.14.0",
    "supabase": "^2.109.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.0"
  }
