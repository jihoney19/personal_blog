# Comma-separated browser origins allowed to call the comments Edge Function.
COMMENTS_ALLOWED_ORIGINS=http://localhost:4321

# Use a long random value. It is used only to create a non-reversible rate-limit key.
COMMENTS_HASH_SECRET=

# Supabase provides these automatically in hosted Edge Functions.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
